# =============================================================================
# Development env (sample). Copy to `.env.development` and tweak per host.
# `.env.development` is gitignored — every developer maintains their own.
# =============================================================================

# Local API + chat. Point at the docker compose stack or your bare-metal
# dev servers.
VITE_API_BASE_URL=http://localhost:3000/api
VITE_CHAT_BASE_URL=http://localhost:3001

# CSP dev-extras. Lets the local browser fetch the dev API + chat over plain
# HTTP / WS without violating the strict prod-shaped CSP in `index.html`.
# Whitespace-separated list of source expressions.
VITE_CSP_DEV_CONNECT=http://localhost:3000 http://localhost:3001 ws://localhost:3001
VITE_CSP_DEV_IMG=http://localhost:3000 http://localhost:3001

# Same OAuth + OneSignal ids as prod (they identify the *project*, not env).
VITE_GOOGLE_CLIENT_ID=765386230641-1be5i4mejr0mql13ib6bk27dj0uq7n8f.apps.googleusercontent.com
VITE_ONESIGNAL_APP_ID=b136e33d-56f0-4fc4-ad08-8c8a534ca447
