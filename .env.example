# Dashboard env contract (Vite inlines VITE_* into the client bundle).
#
# Two real env files exist in this repo:
#   - `.env.production`           — COMMITTED (only public URLs)
#   - `.env.development.example`  — sample, copy to `.env.development`
#
# Anything else with secrets stays out of git (`.env*` is gitignored apart
# from the two files above and this file).
#
# Cheat sheet:
#   - `npm run dev`   reads `.env.development` (your local copy)
#   - `npm run build` reads `.env.production` (committed)
#
# The variable contract below is shared by both modes; values differ.

# ---- API base URLs (REQUIRED) ---------------------------------------------
# Main API base URL. Includes the `/api` suffix.
VITE_API_BASE_URL=

# Chat service base URL (REST + Socket.IO share this host).
VITE_CHAT_BASE_URL=

# ---- CSP dev-only extras ---------------------------------------------------
# Production: leave empty (strict CSP).
# Development: list http(s)/ws(s) sources to allow in connect-src / img-src.
VITE_CSP_DEV_CONNECT=
VITE_CSP_DEV_IMG=

# ---- Third-party (client-side, NOT secret) ---------------------------------
# OneSignal app id is public by design — it identifies the project, not auth.
VITE_ONESIGNAL_APP_ID=

# Google Sign-In client id (public — bound to the OAuth consent screen).
VITE_GOOGLE_CLIENT_ID=
