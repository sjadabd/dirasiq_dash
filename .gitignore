# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/

# Build output (Don't upload dist to GitHub)
dist/
dist-ssr/

# Local env
# Production env (only PUBLIC URLs — no secrets) IS committed so docker builds
# inside the CI / VPS always pick up the right base URLs. Anything else with a
# secret stays out of git.
.env*
!.env.example
!.env.production
!.env.development.example

# IDE and editor folders
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/*.code-snippets
!.vscode/tours

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# System files
.DS_Store

# Cypress cache
/cypress/videos/
/cypress/screenshots/

# Optional local configs
*.local

# Yarn cache
.yarn
